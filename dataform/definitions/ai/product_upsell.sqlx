config {
  type: "view",
  schema: "ai",
  description: "Product upsell strategies generated by Gemini — for CPO dashboard",
  tags: ["ai", "daily_refresh"]
}

WITH product_metrics AS (
  SELECT
    oi.product_id,
    COUNT(DISTINCT o.customer_id) AS unique_buyers,
    SUM(oi.quantity)              AS total_units_sold,
    SUM(oi.subtotal)              AS total_revenue
  FROM ${ref("fct_orders")} o
  JOIN ${ref("stg_order_items")} oi USING (order_id)
  WHERE o.order_date >= DATE_SUB(CURRENT_DATE(), INTERVAL 90 DAY)
  GROUP BY 1
)

SELECT
  p.product_id,
  p.product_name,
  p.category,
  p.sub_category,
  p.brand,
  p.unit_price,
  pm.unique_buyers,
  pm.total_units_sold,
  pm.total_revenue,
  ml_result.ml_generate_text_llm_result  AS gemini_upsell_strategy,
  ml_result.ml_generate_text_status      AS generation_status,
  CURRENT_TIMESTAMP()                    AS generated_at
FROM ${ref("dim_products")} p
JOIN product_metrics pm USING (product_id)
CROSS JOIN UNNEST([
  (SELECT AS STRUCT
    ml_generate_text_llm_result,
    ml_generate_text_status
   FROM ML.GENERATE_TEXT(
     MODEL `vishal-sandpit-474523.ai.gemini_pro_model`,
     (SELECT CONCAT(
       'You are a product strategist. For this product, provide exactly 2 specific strategies:\n',
       '1. A cross-sell recommendation (complementary product or bundle)\n',
       '2. An upsell strategy (premium tier or increased quantity)\n\n',
       'Product: ', p2.product_name, '\n',
       'Category: ', p2.category, '\n',
       'Price: $', CAST(p2.unit_price AS STRING), '\n',
       'Unique Buyers (90 days): ', CAST(pm2.unique_buyers AS STRING), '\n',
       'Total Revenue (90 days): $', CAST(ROUND(pm2.total_revenue, 2) AS STRING)
      ) AS prompt
      FROM ${ref("dim_products")} p2
      JOIN product_metrics pm2 USING (product_id)
      WHERE p2.product_id = p.product_id
     ),
     STRUCT(
       0.3   AS temperature,
       200   AS max_output_tokens,
       TRUE  AS flatten_json_output
     )
   ))
]) AS ml_result
WHERE pm.total_units_sold > 0
