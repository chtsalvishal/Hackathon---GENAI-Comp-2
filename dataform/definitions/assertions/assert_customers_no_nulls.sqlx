config {
  type: "assertion",
  tags: ["quality", "silver"],
  description: "customer_id and email must never be null or empty string in silver.stg_customers"
}

SELECT
  customer_id,
  email
FROM ${ref("stg_customers")}
WHERE
  customer_id IS NULL
  OR TRIM(customer_id) = ''
  OR email IS NULL
  OR TRIM(email) = ''
