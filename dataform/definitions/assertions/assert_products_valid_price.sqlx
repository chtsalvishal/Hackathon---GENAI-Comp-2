config {
  type: "assertion",
  tags: ["quality", "silver"],
  description: "unit_price must be greater than zero in silver.stg_products. Zero or null prices indicate bad source data."
}

SELECT
  product_id,
  product_name,
  unit_price
FROM ${ref("stg_products")}
WHERE
  unit_price IS NULL
  OR unit_price <= 0
