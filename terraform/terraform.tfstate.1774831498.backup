            "description": "Full warehouse refresh \u00e2\u20ac\u201d compiles Dataform and runs all tables on a daily schedule.",
            "effective_labels": {
              "workload": "daily-refresh"
            },
            "id": "projects/vishal-sandpit-474523/locations/australia-southeast1/workflows/daily-refresh-workflow",
            "labels": {
              "workload": "daily-refresh"
            },
            "name": "daily-refresh-workflow",
            "name_prefix": null,
            "project": "vishal-sandpit-474523",
            "region": "australia-southeast1",
            "revision_id": "000001-673",
            "service_account": "projects/vishal-sandpit-474523/serviceAccounts/workflows-sa@vishal-sandpit-474523.iam.gserviceaccount.com",
            "source_contents": "main:\n  params: [args]\n  steps:\n    - init:\n        assign:\n          - project_id: ${sys.get_env(\"GOOGLE_CLOUD_PROJECT_ID\")}\n          - location: ${sys.get_env(\"GOOGLE_CLOUD_LOCATION\")}\n          - repository: \"intelia-warehouse\"\n          - dataform_base: ${\"https://dataform.googleapis.com/v1beta1/projects/\" + project_id + \"/locations/\" + location + \"/repositories/\" + repository}\n\n    - log_start:\n        call: sys.log\n        args:\n          text: \"daily-refresh-workflow started\"\n          severity: INFO\n\n    - create_compilation:\n        call: http.post\n        args:\n          url: ${dataform_base + \"/compilationResults\"}\n          auth:\n            type: OAuth2\n          body:\n            gitCommitish: \"main\"\n        result: compile_resp\n\n    - check_compile:\n        switch:\n          - condition: ${compile_resp.code != 200}\n            raise: ${\"Compilation failed HTTP \" + string(compile_resp.code)}\n\n    - extract_compilation_name:\n        assign:\n          - compilation_name: ${compile_resp.body.name}\n\n    - log_compilation:\n        call: sys.log\n        args:\n          text: ${\"Compilation result - \" + compilation_name}\n          severity: INFO\n\n    - create_invocation:\n        call: http.post\n        args:\n          url: ${dataform_base + \"/workflowInvocations\"}\n          auth:\n            type: OAuth2\n          body:\n            compilationResult: ${compilation_name}\n            invocationConfig:\n              fullyRefreshIncrementalTablesEnabled: true\n              transitiveDependenciesIncluded: true\n              transitiveDependentsIncluded: true\n        result: invoke_resp\n\n    - check_invoke_created:\n        switch:\n          - condition: ${invoke_resp.code != 200}\n            raise: ${\"Invocation creation failed HTTP \" + string(invoke_resp.code)}\n\n    - extract_invocation_name:\n        assign:\n          - invocation_name: ${invoke_resp.body.name}\n          - poll_url: ${\"https://dataform.googleapis.com/v1beta1/\" + invocation_name}\n\n    - log_invocation:\n        call: sys.log\n        args:\n          text: ${\"Invocation started - \" + invocation_name}\n          severity: INFO\n\n    - poll_loop:\n        steps:\n          - poll:\n              call: http.get\n              args:\n                url: ${poll_url}\n                auth:\n                  type: OAuth2\n              result: poll_resp\n\n          - check_state:\n              switch:\n                - condition: ${poll_resp.body.state == \"SUCCEEDED\"}\n                  next: succeeded\n                - condition: ${poll_resp.body.state == \"FAILED\"}\n                  next: failed\n                - condition: ${poll_resp.body.state == \"CANCELING\" or poll_resp.body.state == \"CANCELLED\"}\n                  next: cancelled\n\n          - wait:\n              call: sys.sleep\n              args:\n                seconds: 60\n              next: poll\n\n    - succeeded:\n        call: sys.log\n        args:\n          text: ${\"Daily refresh SUCCEEDED - \" + invocation_name}\n          severity: INFO\n        next: done\n\n    - failed:\n        raise: ${\"Dataform daily refresh FAILED - \" + invocation_name}\n\n    - cancelled:\n        raise: ${\"Dataform daily refresh CANCELLED - \" + invocation_name}\n\n    - done:\n        return: ${invocation_name}\n",
            "state": "ACTIVE",
            "terraform_labels": {
              "workload": "daily-refresh"
            },
            "timeouts": null,
            "update_time": "2026-03-24T00:13:58.357663727Z",
            "user_env_vars": {}
          },
          "sensitive_attributes": [],
