    {
      "module": "module.cloud_workflows",
      "mode": "managed",
      "type": "google_workflows_workflow",
      "name": "delta_ingest",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "call_log_level": "",
            "create_time": "2026-03-24T00:13:58.079457135Z",
            "crypto_key_name": "",
            "description": "Compiles Dataform and invokes only delta-tagged tables when a new file lands in GCS.",
            "effective_labels": {
              "workload": "delta-pipeline"
            },
            "id": "projects/vishal-sandpit-474523/locations/australia-southeast1/workflows/delta-ingest-workflow",
            "labels": {
              "workload": "delta-pipeline"
            },
            "name": "delta-ingest-workflow",
            "name_prefix": null,
            "project": "vishal-sandpit-474523",
            "region": "australia-southeast1",
            "revision_id": "000002-dc2",
            "service_account": "projects/vishal-sandpit-474523/serviceAccounts/workflows-sa@vishal-sandpit-474523.iam.gserviceaccount.com",
            "source_contents": "main:\n  params: [event]\n  steps:\n    - init:\n        assign:\n          - project_id: ${sys.get_env(\"GOOGLE_CLOUD_PROJECT_ID\")}\n          - location: ${sys.get_env(\"GOOGLE_CLOUD_LOCATION\")}\n          - repository: \"intelia-warehouse\"\n          - tag: \"delta\"\n          - dataform_base: ${\"https://dataform.googleapis.com/v1beta1/projects/\" + project_id + \"/locations/\" + location + \"/repositories/\" + repository}\n\n    - log_event:\n        call: sys.log\n        args:\n          text: \"delta-ingest triggered\"\n          severity: INFO\n\n    - list_compilations:\n        call: http.get\n        args:\n          url: ${dataform_base + \"/compilationResults?pageSize=5\"}\n          auth:\n            type: OAuth2\n        result: list_resp\n\n    - check_list:\n        switch:\n          - condition: ${list_resp.code != 200}\n            raise: ${\"List compilations failed HTTP \" + string(list_resp.code)}\n\n    - extract_compilation_name:\n        assign:\n          - compilation_name: ${list_resp.body.compilationResults[0].name}\n\n    - log_compilation:\n        call: sys.log\n        args:\n          text: ${\"Compilation result - \" + compilation_name}\n          severity: INFO\n\n    - create_invocation:\n        call: http.post\n        args:\n          url: ${dataform_base + \"/workflowInvocations\"}\n          auth:\n            type: OAuth2\n          body:\n            compilationResult: ${compilation_name}\n            invocationConfig:\n              includedTags:\n                - ${tag}\n              transitiveDependenciesIncluded: true\n              transitiveDependentsIncluded: false\n        result: invoke_resp\n\n    - check_invoke_created:\n        switch:\n          - condition: ${invoke_resp.code != 200}\n            raise: ${\"Invocation creation failed HTTP \" + string(invoke_resp.code)}\n\n    - extract_invocation_name:\n        assign:\n          - invocation_name: ${invoke_resp.body.name}\n          - poll_url: ${\"https://dataform.googleapis.com/v1beta1/\" + invocation_name}\n\n    - log_invocation:\n        call: sys.log\n        args:\n          text: ${\"Invocation started - \" + invocation_name}\n          severity: INFO\n\n    - poll_loop:\n        steps:\n          - poll:\n              call: http.get\n              args:\n                url: ${poll_url}\n                auth:\n                  type: OAuth2\n              result: poll_resp\n\n          - check_state:\n              switch:\n                - condition: ${poll_resp.body.state == \"SUCCEEDED\"}\n                  next: succeeded\n                - condition: ${poll_resp.body.state == \"FAILED\"}\n                  next: failed\n                - condition: ${poll_resp.body.state == \"CANCELING\" or poll_resp.body.state == \"CANCELLED\"}\n                  next: cancelled\n\n          - wait:\n              call: sys.sleep\n              args:\n                seconds: 30\n              next: poll\n\n    - succeeded:\n        call: sys.log\n        args:\n          text: ${\"Invocation SUCCEEDED - \" + invocation_name}\n          severity: INFO\n        next: done\n\n    - failed:\n        raise: ${\"Dataform invocation FAILED - \" + invocation_name}\n\n    - cancelled:\n        raise: ${\"Dataform invocation CANCELLED - \" + invocation_name}\n\n    - done:\n        return: ${invocation_name}\n",
            "state": "ACTIVE",
            "terraform_labels": {
              "workload": "delta-pipeline"
            },
            "timeouts": null,
            "update_time": "2026-03-24T01:11:25.246312651Z",
            "user_env_vars": {}
          },
          "sensitive_attributes": [],
