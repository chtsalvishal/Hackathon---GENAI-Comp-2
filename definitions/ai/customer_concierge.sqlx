config {
  type: "view",
  schema: "ai",
  description: "Customer Concierge — dynamic view for real-time Gemini results.",
  tags: ["ai", "daily_refresh"],
  dependencies: ["gemini_pro_model"]
}

WITH base AS (
  SELECT *
  FROM ${ref("dim_customers_analyst")}
  WHERE order_count > 0
),

ai_results AS (
  SELECT
    customer_id,
    ml_generate_text_llm_result AS gemini_persona_and_strategy,
    ml_generate_text_status     AS generation_status
  FROM ML.GENERATE_TEXT(
    MODEL `${database()}.ai.gemini_pro_model`,
    (
      SELECT
        customer_id,
        CONCAT(
          'Customer success expert.\n',
          'Output:\n- 2-sentence persona\n- 1 retention action\n\n',
          'Segment: ', customer_segment,
          ', LTV: ', lifetime_value_band,
          ', Orders: ', order_count,
          ', Days Since Purchase: ', days_since_last_purchase,
          ', Risk: ', churn_risk,
          ', Country: ', country
        ) AS prompt
      FROM base
    ),
    STRUCT(
      0.2  AS temperature,
      128  AS max_output_tokens,
      TRUE AS flatten_json_output
    )
  )
)

SELECT
  b.customer_id,
  b.customer_name,
  b.customer_segment,
  b.churn_risk,
  b.lifetime_value_band,
  b.order_count,
  b.last_purchase_date,
  b.days_since_last_purchase,
  b.country,
  r.gemini_persona_and_strategy,
  r.generation_status,
  CURRENT_TIMESTAMP() AS generated_at
FROM base b
JOIN ai_results r USING (customer_id)
