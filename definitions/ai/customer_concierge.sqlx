config {
  type: "table",
  schema: "ai",
  name: "customer_concierge",
  tags: ["ai", "daily_refresh"]
}

post_operations {
  DROP TABLE IF EXISTS ${ref("customer_ai_1")};
  DROP TABLE IF EXISTS ${ref("customer_ai_2")};
  DROP TABLE IF EXISTS ${ref("customer_ai_3")};
  DROP TABLE IF EXISTS ${ref("customer_ai_4")};
}

WITH unioned AS (
  SELECT * FROM ${ref("customer_ai_1")}
  UNION ALL
  SELECT * FROM ${ref("customer_ai_2")}
  UNION ALL
  SELECT * FROM ${ref("customer_ai_3")}
  UNION ALL
  SELECT * FROM ${ref("customer_ai_4")}
)

SELECT
  *,
  CONCAT("Persona: ", persona, "\nStrategy: ", strategy) AS gemini_persona_and_strategy,
  status                                          AS generation_status
FROM unioned
