config {
  type: "view",
  schema: "ai",
  description: "Customer Concierge — Gemini-generated persona and retention strategy per customer using ML.GENERATE_TEXT",
  tags: ["ai", "daily_refresh"],
  dependOnDependencyAssertions: true
}

-- Bulk inference: pass all eligible customers to Gemini in one call for efficiency
WITH ai_results AS (
  SELECT
    customer_id,
    ml_generate_text_llm_result AS gemini_persona_and_strategy,
    ml_generate_text_status     AS generation_status
  FROM ML.GENERATE_TEXT(
    MODEL `vishal-sandpit-474523.ai.gemini_pro_model`,
    (
      SELECT
        customer_id,
        CONCAT(
          'You are a customer success expert. Analyse this customer profile and provide:\n',
          '1. A 2-sentence persona describing their behaviour and value to the business.\n',
          '2. One specific, actionable retention strategy tailored to their situation.\n\n',
          'Customer: ', customer_name, '\n',
          'Segment: ', customer_segment, '\n',
          'Lifetime Value: $', CAST(ROUND(total_lifetime_value, 2) AS STRING), '\n',
          'Total Orders: ', CAST(order_count AS STRING), '\n',
          'Average Order Value: $', CAST(ROUND(avg_order_value, 2) AS STRING), '\n',
          'Days Since Last Purchase: ', CAST(days_since_last_purchase AS STRING), '\n',
          'Churn Risk: ', churn_risk, '\n',
          'Country: ', country
        ) AS prompt
      FROM ${ref("dim_customers")}
      WHERE order_count > 0
    ),
    STRUCT(
      0.2   AS temperature,
      256   AS max_output_tokens,
      TRUE  AS flatten_json_output
    )
  )
)

SELECT
  c.customer_id,
  c.customer_name,
  c.email,
  c.customer_segment,
  c.churn_risk,
  c.total_lifetime_value,
  c.order_count,
  c.avg_order_value,
  c.last_purchase_date,
  c.days_since_last_purchase,
  c.country,
  c.total_lifetime_value  AS raw_ltv,
  c.order_count           AS raw_order_count,
  c.churn_risk            AS raw_churn_risk,
  r.gemini_persona_and_strategy,
  r.generation_status,
  CURRENT_TIMESTAMP()     AS generated_at
FROM ${ref("dim_customers")} c
JOIN ai_results r USING (customer_id)
