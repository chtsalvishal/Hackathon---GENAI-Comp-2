config {
  type: "table",
  schema: "ai",
  tags: ["ai", "daily_refresh"],
  dependencies: ["dim_products", "gemini_pro_model"]
  -- No dependency on product_ai_3 — runs in PARALLEL with shards 1, 2, 3
}

-- Product AI Shard 4/4 — processes products where FARM_FINGERPRINT MOD 4 = 3
-- Single ML.GENERATE_TEXT call (no inner sub-batching)
-- flatten_json_output=TRUE: returns text directly, no nested JSON navigation needed

WITH base AS (
  SELECT
    product_id,
    CONCAT(
      'Respond with ONLY a JSON object. No markdown, no code blocks.\n',
      'Format: {"cross_sell":"complementary product suggestion","upsell":"premium version or accessory suggestion"}\n',
      'Product:', product_name, ' Category:', category
    ) AS prompt
  FROM ${ref("dim_products")}
  WHERE product_id IS NOT NULL
    AND MOD(ABS(FARM_FINGERPRINT(product_id)), 4) = 3
),

ai_output AS (
  SELECT
    product_id,
    ml_generate_text_llm_result AS raw_text,
    ml_generate_text_status     AS status
  FROM ML.GENERATE_TEXT(
    MODEL `${database()}.ai.gemini_pro_model`,
    (SELECT product_id, prompt FROM base),
    STRUCT(
      0.1  AS temperature,
      150  AS max_output_tokens,
      TRUE AS flatten_json_output
    )
  )
)

SELECT
  product_id,
  COALESCE(JSON_VALUE(REGEXP_EXTRACT(raw_text, r'\{[\s\S]*\}'), '$.cross_sell'), 'No cross-sell strategy') AS cross_sell,
  COALESCE(JSON_VALUE(REGEXP_EXTRACT(raw_text, r'\{[\s\S]*\}'), '$.upsell'),     'Basic upsell')           AS upsell,
  status,
  CURRENT_TIMESTAMP() AS generated_at
FROM ai_output
WHERE status IS NOT NULL
