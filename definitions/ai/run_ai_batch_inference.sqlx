config {
  type: "operations",
  schema: "ai",
  name: "run_ai_batch_inference",
  tags: ["ai", "daily_refresh"],
  dependencies: ["dim_customers_analyst", "dim_products", "gemini_pro_model"]
}

CREATE OR REPLACE PROCEDURE `${database()}.ai.sp_run_gemini_inference`()
LANGUAGE PYTHON
OPTIONS (
  connection = 'australia-southeast1.gemini-pro-connection'
)
AS R"""
import json
from google.cloud import bigquery

def main(client):
    project_id = "vishal-sandpit-474523"
    
    # --- TASK 1: Customer Concierge ---
    query_c = "SELECT customer_id, customer_segment, churn_risk, country FROM `%s.gold.dim_customers_analyst` WHERE order_count > 0 LIMIT 1000" % project_id
    rows_c = list(client.query(query_c).result())
    batches_c = [rows_c[i:i + 10] for i in range(0, len(rows_c), 10)]
    results_c = []
    
    for batch in batches_c:
        prompt_data = "\n".join(["ID: %s, Segment: %s, Risk: %s" % (r.customer_id, r.customer_segment, r.churn_risk) for r in batch])
        full_prompt = "Return ONLY valid JSON array. One persona per ID.\nCustomers:\n" + prompt_data
        
        query = "SELECT * FROM ML.GENERATE_TEXT(MODEL `%s.ai.gemini_pro_model`, (SELECT \"\"\"%s\"\"\" AS prompt), STRUCT(0.1 AS temperature, 1024 AS max_output_tokens, 'application/json' AS response_mime_type))" % (project_id, full_prompt)
        try:
            res = list(client.query(query).result())[0]
            clean_res = res.ml_generate_text_llm_result.replace("```json", "").replace("```", "").strip()
            results_c.extend(json.loads(clean_res))
        except: pass

    if results_c:
        client.load_table_from_json(results_c, "%s.ai.customer_concierge" % project_id, job_config=bigquery.LoadJobConfig(write_disposition="WRITE_TRUNCATE")).result()

    # --- TASK 2: Product Upsell ---
    query_p = "SELECT product_id, product_name, category FROM `%s.gold.dim_products` LIMIT 500" % project_id
    rows_p = list(client.query(query_p).result())
    batches_p = [rows_p[i:i + 10] for i in range(0, len(rows_p), 10)]
    results_p = []

    for batch in batches_p:
        prompt_data = "\n".join(["ID: %s, Name: %s, Category: %s" % (r.product_id, r.product_name, r.category) for r in batch])
        full_prompt = "Return ONLY valid JSON array. One cross-sell strategy per ID.\nProducts:\n" + prompt_data
        
        query = "SELECT * FROM ML.GENERATE_TEXT(MODEL `%s.ai.gemini_pro_model`, (SELECT \"\"\"%s\"\"\" AS prompt), STRUCT(0.1 AS temperature, 1024 AS max_output_tokens, 'application/json' AS response_mime_type))" % (project_id, full_prompt)
        try:
            res = list(client.query(query).result())[0]
            clean_res = res.ml_generate_text_llm_result.replace("```json", "").replace("```", "").strip()
            results_p.extend(json.loads(clean_res))
        except: pass

    if results_p:
        client.load_table_from_json(results_p, "%s.ai.product_upsell" % project_id, job_config=bigquery.LoadJobConfig(write_disposition="WRITE_TRUNCATE")).result()

main(bigquery.Client())
""";

CALL `${database()}.ai.sp_run_gemini_inference`();
