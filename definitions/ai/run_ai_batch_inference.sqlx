config {
  type: "operations",
  schema: "ai",
  name: "run_ai_batch_inference",
  tags: ["ai", "daily_refresh"],
  dependencies: ["dim_customers_analyst", "dim_products", "gemini_pro_model"]
}

CREATE OR REPLACE PROCEDURE `${database()}.ai.sp_run_gemini_inference`()
LANGUAGE PYTHON
OPTIONS (
  connection = 'australia-southeast1.gemini-pro-connection'
)
AS R"""
import json
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed
from google.cloud import bigquery

def main(client):
    project_id = "vishal-sandpit-474523"
    current_time = datetime.now().isoformat()
    
    # --- TASK 0: Initialize Tables (Schema Sync with Prompts) ---
    init_queries = [
        "CREATE TABLE IF NOT EXISTS `%s.ai.customer_concierge` (customer_id STRING, persona STRING, strategy STRING, generated_at TIMESTAMP)" % project_id,
        "CREATE TABLE IF NOT EXISTS `%s.ai.product_upsell` (product_id STRING, cross_sell STRING, upsell STRING, generated_at TIMESTAMP)" % project_id
    ]
    for q in init_queries:
        client.query(q).result()

    # --- TASK 1: Customer Concierge (Parallel 10x) ---
    query_c = "SELECT customer_id, customer_segment, churn_risk FROM `%s.gold.dim_customers_analyst` WHERE order_count > 0 LIMIT 1000" % project_id
    rows_c = list(client.query(query_c).result())
    batches_c = [rows_c[i:i + 20] for i in range(0, len(rows_c), 20)]
    results_c = []

    def run_batch_customer(batch):
        prompt_data = "\n".join(["ID: %s, Segment: %s, Risk: %s" % (r.customer_id, r.customer_segment, r.churn_risk) for r in batch])
        full_prompt = "Return ONLY valid JSON array:\n[{\"customer_id\":\"\",\"persona\":\"\",\"strategy\":\"\"}]\n\nCustomers:\n" + prompt_data
        
        # Using triple-quotes for the prompt inside the SQL to handle newlines correctly
        query = """
        SELECT * FROM ML.GENERATE_TEXT(
          MODEL `%s.ai.gemini_pro_model`,
          (SELECT \"\"\"%s\"\"\" AS prompt),
          STRUCT(0.1 AS temperature, 1024 AS max_output_tokens)
        )
        """ % (project_id, full_prompt.replace('"', '\\"'))
        try:
            res = list(client.query(query).result())[0]
            clean = res.ml_generate_text_llm_result.replace("```json", "").replace("```", "").strip()
            batch_data = json.loads(clean)
            # Add timestamp metadata
            for item in batch_data: item['generated_at'] = current_time
            return batch_data
        except: return []

    with ThreadPoolExecutor(max_workers=10) as executor:
        futures = [executor.submit(run_batch_customer, batch) for batch in batches_c]
        for f in as_completed(futures):
            results_c.extend(f.result())

    if results_c:
        client.load_table_from_json(results_c, "%s.ai.customer_concierge" % project_id, job_config=bigquery.LoadJobConfig(write_disposition="WRITE_TRUNCATE")).result()

    # --- TASK 2: Product Upsell (Parallel 10x) ---
    query_p = "SELECT product_id, product_name, category FROM `%s.gold.dim_products` LIMIT 500" % project_id
    rows_p = list(client.query(query_p).result())
    batches_p = [rows_p[i:i + 20] for i in range(0, len(rows_p), 20)]
    results_p = []

    def run_batch_product(batch):
        prompt_data = "\n".join(["ID: %s, Name: %s, Category: %s" % (r.product_id, r.product_name, r.category) for r in batch])
        full_prompt = "Return ONLY valid JSON array:\n[{\"product_id\":\"\",\"cross_sell\":\"\",\"upsell\":\"\"}]\n\nProducts:\n" + prompt_data
        
        query = """
        SELECT * FROM ML.GENERATE_TEXT(
          MODEL `%s.ai.gemini_pro_model`,
          (SELECT \"\"\"%s\"\"\" AS prompt),
          STRUCT(0.1 AS temperature, 1024 AS max_output_tokens)
        )
        """ % (project_id, full_prompt.replace('"', '\\"'))
        try:
            res = list(client.query(query).result())[0]
            clean = res.ml_generate_text_llm_result.replace("```json", "").replace("```", "").strip()
            batch_data = json.loads(clean)
            # Add timestamp metadata
            for item in batch_data: item['generated_at'] = current_time
            return batch_data
        except: return []

    with ThreadPoolExecutor(max_workers=10) as executor:
        futures = [executor.submit(run_batch_product, batch) for batch in batches_p]
        for f in as_completed(futures):
            results_p.extend(f.result())

    if results_p:
        client.load_table_from_json(results_p, "%s.ai.product_upsell" % project_id, job_config=bigquery.LoadJobConfig(write_disposition="WRITE_TRUNCATE")).result()

main(bigquery.Client())
""";

CALL `${database()}.ai.sp_run_gemini_inference`();
