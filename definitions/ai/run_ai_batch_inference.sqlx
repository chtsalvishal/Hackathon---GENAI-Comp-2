config {
  type: "operations",
  schema: "ai",
  name: "run_ai_batch_inference",
  tags: ["ai", "daily_refresh"],
  dependencies: ["dim_customers_analyst", "gemini_pro_model"] -- 👈 Added model dependency
}

-- Python Stored Procedure: Zero-Server Batching
CREATE OR REPLACE PROCEDURE `${database()}.ai.sp_run_gemini_inference`()
LANGUAGE PYTHON
OPTIONS (
  connection = 'australia-southeast1.gemini-pro-connection'
)
AS R"""
import json
from google.cloud import bigquery

def main(client): -- 👈 Renamed to match call at bottom
    # 1. Fetch data from Gold (Using Ref would be hard here, so we use string formatting)
    project_id = "vishal-sandpit-474523"
    query = f"SELECT customer_id, customer_segment, churn_risk, country FROM `{project_id}.gold.dim_customers_analyst` WHERE order_count > 0 LIMIT 1000"
    job = client.query(query)
    rows = list(job.result())
    
    # 2. Batch into groups of 10 for speed
    batches = [rows[i:i + 10] for i in range(0, len(rows), 10)]
    all_results = []
    
    for batch in batches:
        # Build prompt for 10 rows
        prompt_data = "\n".join([f"ID: {r.customer_id}, Segment: {r.customer_segment}, Risk: {r.churn_risk}" for r in batch])
        full_prompt = f"Return ONLY valid JSON array. One persona per ID.\nCustomers:\n{prompt_data}"
        
        # Call Gemini via ML.GENERATE_TEXT (Note: triple quotes inside f-string need care)
        batch_query = f'''
        SELECT * FROM ML.GENERATE_TEXT(
          MODEL `{project_id}.ai.gemini_pro_model`,
          (SELECT """{full_prompt}""" AS prompt),
          STRUCT(0.1 AS temperature, 1024 AS max_output_tokens, 'application/json' AS response_mime_type)
        )
        '''
        try:
            res = list(client.query(batch_query).result())[0]
            # Parse the batch JSON
            clean_res = res.ml_generate_text_llm_result.replace("```json", "").replace("```", "").strip()
            all_results.extend(json.loads(clean_res))
        except Exception as e:
            print(f"Error in batch: {e}")

    # 3. Write results to Physical Table
    if all_results:
        table_id = f"{project_id}.ai.customer_concierge_results"
        job_config = bigquery.LoadJobConfig(write_disposition="WRITE_TRUNCATE")
        client.load_table_from_json(all_results, table_id, job_config=job_config).result()

main(bigquery.Client())
""";

-- Execute the procedure
CALL `${database()}.ai.sp_run_gemini_inference`();
