config {
  type: "table",
  schema: "ai",
  description: "Product upsell strategies — materialized table to avoid redundant LLM calls.",
  tags: ["ai", "daily_refresh"],
  dependencies: ["gemini_pro_model"],
  bigquery: {
    clusterBy: ["category", "brand"]
  }
}

-- Use last 90 days of available data (not CURRENT_DATE) so historical datasets are supported
WITH max_order_date AS (
  SELECT MAX(order_date) AS latest FROM ${ref("fct_orders")}
),

product_metrics AS (
  SELECT
    oi.product_id,
    COUNT(DISTINCT o.customer_id) AS unique_buyers,
    SUM(oi.quantity)              AS total_units_sold,
    SUM(oi.subtotal)              AS total_revenue
  FROM ${ref("fct_orders")} o
  JOIN ${ref("stg_order_items")} oi USING (order_id)
  CROSS JOIN max_order_date m
  WHERE o.order_date >= DATE_SUB(m.latest, INTERVAL 90 DAY)
  GROUP BY 1
),

-- Bulk inference: pass all eligible products to Gemini in one call
ai_results AS (
  SELECT
    product_id,
    ml_generate_text_llm_result AS gemini_upsell_strategy,
    ml_generate_text_status     AS generation_status
  FROM ML.GENERATE_TEXT(
    MODEL `vishal-sandpit-474523.ai.gemini_pro_model`,
    (
      SELECT
        p.product_id,
        CONCAT(
          'You are a product strategist. For this product, provide exactly 2 specific strategies:\n',
          '1. A cross-sell recommendation (complementary product or bundle)\n',
          '2. An upsell strategy (premium tier or increased quantity)\n\n',
          'Product: ', p.product_name, '\n',
          'Category: ', p.category, '\n',
          'Price: $', CAST(p.unit_price AS STRING), '\n',
          'Unique Buyers (last 90 days of data): ', CAST(pm.unique_buyers AS STRING), '\n',
          'Total Revenue (last 90 days of data): $', CAST(ROUND(pm.total_revenue, 2) AS STRING)
        ) AS prompt
      FROM ${ref("dim_products")} p
      JOIN product_metrics pm USING (product_id)
      WHERE pm.total_units_sold > 0
    ),
    STRUCT(
      0.3   AS temperature,
      200   AS max_output_tokens,
      TRUE  AS flatten_json_output
    )
  )
)

SELECT
  p.product_id,
  p.product_name,
  p.category,
  p.sub_category,
  p.brand,
  p.unit_price,
  pm.unique_buyers,
  pm.total_units_sold,
  pm.total_revenue,
  r.gemini_upsell_strategy,
  r.generation_status,
  CURRENT_TIMESTAMP() AS generated_at
FROM ${ref("dim_products")} p
JOIN product_metrics pm USING (product_id)
JOIN ai_results r USING (product_id)
