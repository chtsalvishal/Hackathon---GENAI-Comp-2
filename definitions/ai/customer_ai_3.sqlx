config {
  type: "table",
  schema: "ai",
  tags: ["ai"],  // manual fallback only — replaced by Cloud Run in daily workflow
  dependencies: ["dim_customers_analyst", "gemini_pro_model"]
}

-- Customer AI Shard 3/4 — processes customers where FARM_FINGERPRINT MOD 4 = 2
-- Single ML.GENERATE_TEXT call (no inner sub-batching)
-- flatten_json_output=TRUE: BQ ML returns text in ml_generate_text_llm_result
-- status = '' on success, error message string on failure (BQ ML behaviour)

WITH base AS (
  SELECT
    customer_id,
    CONCAT(
      'Respond with ONLY a JSON object. No markdown, no code blocks.\n',
      'Format: {"persona":"2-sentence customer profile","strategy":"one specific retention action"}\n',
      'Segment:', COALESCE(customer_segment, 'Unknown'), ' Risk:', COALESCE(churn_risk, 'Unknown')
    ) AS prompt
  FROM ${ref("dim_customers_analyst")}
  WHERE order_count > 0
    AND customer_segment IS NOT NULL
    AND churn_risk IS NOT NULL
    AND MOD(ABS(FARM_FINGERPRINT(customer_id)), 4) = 2
),

ai_output AS (
  SELECT
    customer_id,
    ml_generate_text_llm_result AS raw_text,
    ml_generate_text_status     AS status
  FROM ML.GENERATE_TEXT(
    MODEL `${database()}.ai.gemini_pro_model`,
    (SELECT customer_id, prompt FROM base),
    STRUCT(
      0.1  AS temperature,
      150  AS max_output_tokens,
      TRUE AS flatten_json_output
    )
  )
)

SELECT
  customer_id,
  COALESCE(JSON_VALUE(REGEXP_EXTRACT(raw_text, r'\{[\s\S]*\}'), '$.persona'),  'Valued customer')   AS persona,
  COALESCE(JSON_VALUE(REGEXP_EXTRACT(raw_text, r'\{[\s\S]*\}'), '$.strategy'), 'Monitor engagement') AS strategy,
  status,
  CURRENT_TIMESTAMP() AS generated_at
FROM ai_output
WHERE status = ''  -- Empty string = success in BQ ML; non-empty string = error, exclude from output
