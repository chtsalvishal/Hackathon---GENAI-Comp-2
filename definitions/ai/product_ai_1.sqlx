config {
  type: "table",
  schema: "ai",
  tags: ["ai", "daily_refresh"],
  dependencies: ["dim_products", "gemini_pro_model"]
}

WITH base AS (
  SELECT
    product_id,
    product_name,
    category,
    CAST(FLOOR(ABS(FARM_FINGERPRINT(product_id))/1000) AS INT64) AS batch_id
  FROM ${ref("dim_products")}
  WHERE product_id IS NOT NULL
    AND MOD(ABS(FARM_FINGERPRINT(product_id)), 4) = 0
),

ai_batch_0 AS (
  SELECT
    product_id,
    ml_generate_text_llm_result AS raw_output,
    ml_generate_text_status AS status
  FROM ML.GENERATE_TEXT(
    MODEL `${database()}.ai.gemini_pro_model`,
    (
      SELECT
        product_id,
        CONCAT(
          'Return ONLY valid JSON array.\n',
          'Do not include markdown or explanation.\n',
          'If invalid, return [].\n\n',
          'Format:\n',
          '[{"product_id":"","cross_sell":"","upsell":""}]\n\n',
          'Name: ', product_name,
          ', Category: ', category
        ) AS prompt
      FROM base
      WHERE batch_id = 0
    ),
    STRUCT(
      0.1 AS temperature,
      256 AS max_output_tokens,
      FALSE AS flatten_json_output
    )
  )
),

ai_batch_1 AS (
  SELECT
    product_id,
    ml_generate_text_llm_result AS raw_output,
    ml_generate_text_status AS status
  FROM ML.GENERATE_TEXT(
    MODEL `${database()}.ai.gemini_pro_model`,
    (
      SELECT
        product_id,
        CONCAT(
          'Return ONLY valid JSON array.\n',
          'Do not include markdown or explanation.\n',
          'If invalid, return [].\n\n',
          'Format:\n',
          '[{"product_id":"","cross_sell":"","upsell":""}]\n\n',
          'Name: ', product_name,
          ', Category: ', category
        ) AS prompt
      FROM base
      WHERE batch_id = 1
    ),
    STRUCT(
      0.1 AS temperature,
      256 AS max_output_tokens,
      FALSE AS flatten_json_output
    )
  )
),

combined AS (
  SELECT * FROM ai_batch_0
  UNION ALL
  SELECT * FROM ai_batch_1
),

cleaned AS (
  SELECT
    *,
    REGEXP_REPLACE(raw_output, r"^```json\n|```$", "") AS clean_output
  FROM combined
)

SELECT
  product_id,
  COALESCE(JSON_VALUE(clean_output, '$[0].cross_sell'), JSON_VALUE(clean_output, '$.cross_sell')) AS cross_sell,
  COALESCE(JSON_VALUE(clean_output, '$[0].upsell'), JSON_VALUE(clean_output, '$.upsell')) AS upsell,
  status,
  CURRENT_TIMESTAMP() AS generated_at
FROM cleaned
WHERE raw_output IS NOT NULL
