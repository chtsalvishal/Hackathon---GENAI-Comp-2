config {
  type: "operations",
  schema: "bronze",
  description: "Loads product delta batches from GCS (vishal-sandpit-474523-delta-staging) into a managed BigQuery table with full schema autodetection. New columns added to the CSV are automatically captured on the next run.",
  tags: ["bronze", "delta"],
  hasOutput: true
}

-- Stage 1: Create an temporary external table to auto-detect schema
CREATE OR REPLACE EXTERNAL TABLE `${database()}.bronze.ext_products_delta_ext`
OPTIONS (
  format = 'CSV',
  uris = ['gs://intelia-hackathon-files/batch_01_products_delta.csv', 'gs://vishal-sandpit-474523-delta-staging/*_products_delta.csv'],
  skip_leading_rows = 1,
  ignore_unknown_values = true
);

-- Stage 2: Materialize as a native table
CREATE OR REPLACE TABLE `${database()}.bronze.ext_products_delta`
AS SELECT * FROM `${database()}.bronze.ext_products_delta_ext`;

-- Cleanup
DROP EXTERNAL TABLE IF EXISTS `${database()}.bronze.ext_products_delta_ext`;
